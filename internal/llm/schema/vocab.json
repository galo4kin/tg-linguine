{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VocabExtraction",
  "type": "object",
  "additionalProperties": false,
  "required": ["words"],
  "properties": {
    "words": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "surface_form",
          "lemma",
          "pos",
          "transcription_ipa",
          "translation_native",
          "example_target",
          "example_native"
        ],
        "properties": {
          "surface_form":       { "type": "string" },
          "lemma":              { "type": "string" },
          "pos":                { "type": "string" },
          "transcription_ipa":  { "type": "string" },
          "translation_native": { "type": "string" },
          "example_target":     { "type": "string" },
          "example_native":     { "type": "string" }
        }
      }
    }
  }
}
