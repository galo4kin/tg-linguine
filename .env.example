# Telegram bot token from @BotFather (required)
BOT_TOKEN=

# SQLite database path
DB_PATH=./bot.db

# Log file path (rotated by lumberjack)
LOG_PATH=./bot.log

# Base64-encoded 32-byte AES encryption key (required)
ENCRYPTION_KEY=

# HTTP client timeout in seconds
HTTP_TIMEOUT_SEC=20

# Max article fetch size in KB
MAX_ARTICLE_SIZE_KB=512

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Log rotation: max file size in MB before rotation
LOG_MAX_SIZE_MB=10

# Number of old log files to keep
LOG_MAX_BACKUPS=5

# Max age of log files in days
LOG_MAX_AGE_DAYS=30

# Set to true to also write logs to stdout (useful in dev)
LOG_STDOUT=false
