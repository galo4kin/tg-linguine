# Telegram bot token from @BotFather (required)
BOT_TOKEN=

# SQLite database path
DB_PATH=./bot.db

# Log file path (rotated by lumberjack)
LOG_PATH=./bot.log

# Base64-encoded 32-byte AES encryption key (required).
# Generate once: openssl rand -base64 32
# WARNING: losing this key makes all stored user API keys unrecoverable —
# back it up securely (password manager / encrypted volume).
ENCRYPTION_KEY=

# HTTP client timeout in seconds (used for both Groq calls and the article
# extractor)
HTTP_TIMEOUT_SEC=20

# Max article fetch size in KB (extractor refuses larger payloads)
MAX_ARTICLE_SIZE_KB=512

# Groq model used for analysis & adapt
GROQ_MODEL=llama-3.3-70b-versatile

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Log rotation: max file size in MB before rotation
LOG_MAX_SIZE_MB=10

# Number of old log files to keep
LOG_MAX_BACKUPS=5

# Max age of log files in days
LOG_MAX_AGE_DAYS=30

# Set to true to also write logs to stdout (useful in dev)
LOG_STDOUT=false

# Per-user rate limit: how many article URLs may be analyzed per hour
RATE_LIMIT_PER_HOUR=10

# Token-budget cap per article — articles whose rune/4 estimate exceeds this
# are rejected before any LLM call (no token spend on impossible inputs)
MAX_TOKENS_PER_ARTICLE=7000

# Yandex Dictionary API key for word translation enrichment (optional).
# Get it at https://yandex.cloud/ru/docs/translate/
# When empty, LLM-generated translations are used as-is.
YANDEX_DICT_API_KEY=

# Telegram user id админа (получить через @userinfobot).
# Пусто/0 = админ-функции выключены (ни команд, ни стартового пинга).
# Пример (текущий владелец):
ADMIN_USER_ID=1995215
